{{#unless actor.system.settings.ignoreDPLimit}}
<h3>
  Supernatural DP Limit:
  {{actor.system.abilities.primary.abilityLimits.Supernatural.current}}
  /
  {{actor.system.abilities.primary.abilityLimits.Supernatural.final}}
</h3>
{{/unless}}
<div class="secondary-block">
  <table class="ability-table">
    <thead>
      <tr>
        <th class="ability-table-name">
          Ability
        </th>
        <th>
          Base
        </th>
        <th>
          Bonus
        </th>
        <th>
          Class
        </th>
        <th>
          Final
        </th>
      </tr>
    </thead>
    <tbody>
      {{#each actor.system.abilities.primary.Supernatural as |ability key|}}
        <tr>
          <td>
            {{localize (concat "ABF.Ability." key)}}
          </td>
        {{#if (in key "MagicAccumulation")}}
        <td></td>
        {{else}}
          <td>
            <input
              class="mod-input-resize-char primary-input"
              data-name="{{key}}"
              data-cost="{{ability.cost}}"
              type="number"
              value="{{ability.base}}"
              name="system.abilities.primary.Supernatural.{{key}}.base"
              {{#if @root.actor.system.lockUi}}disabled{{/if}}
              data-tooltip="
              <div><strong>DP Cost:</strong> {{ability.cost}}</div>
            "
            />
          </td>
          {{/if}}
        {{#if (in key "Zeon" "MagicAccumulation" "MAMultiples")}}
        <td></td>
        {{else}}
          <td>
            <input
              class="mod-input-resize-char"
              type="number"
              value="{{ability.bonus}}"
              name="system.abilities.primary.Supernatural.{{key}}.bonus"
              {{#if @root.actor.system.lockUi}}disabled{{/if}}
            />
          </td>
        {{/if}}
          <td>
            {{ability.class}}
          </td>
        {{#if (in key "Zeon" "MagicAccumulation" "MAMultiples")}}
        <td>{{ability.final}}</td>
        {{else}}
          {{#if (in key "MagicProjection")}}
            <td data-tooltip="Defensive Final: {{ability.defensiveFinal}}">
              {{ability.offensiveFinal}}
            </td>
          {{else}}
            <td class="ability-roll clickable" data-category="Supernatural" data-ability="{{key}}">
              {{ability.final}}
            </td>

          {{/if}}
        {{/if}}
        </tr>
      {{/each}}
    </tbody>
  </table>
</div>