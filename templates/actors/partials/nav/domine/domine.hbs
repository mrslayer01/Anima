<div class="combat-grid-core">
  <div class="combat-left-core">
    <section class="zeon block">
      <h3>
        Martial Knowledge
      </h3>

      <div class="field-row">
        <label class="path-name">
          Bonus
        </label>
        
        <span class="path-name">
          <input
            class="mod-input-resize-char"
            type="number"
            value="{{system.martialKnowledge.bonus}}"
            name="system.martialKnowledge.bonus"
            {{#if @root.actor.system.lockUi}}disabled{{/if}}
          />
        </span>
      </div>

      <div class="field-row">
        <label class="path-name">
          Class
        </label>
        <span class="path-name">
          {{system.martialKnowledge.class}}
        </span>
      </div>

      <div class="field-row">
        <label class="path-name">
          Remaining
        </label>
        <span class="path-name">
          {{system.martialKnowledge.remaining}} / {{system.martialKnowledge.final}}
        </span>
      </div>
    </section>

    <section>
      <h3>
        Ki
      </h3>
      <div class="imbalance-group">
        <h4 
          class="clickable ki-accumulation" 
          data-tooltip="Click to start Ki Accumulation">
          Ki Accumulation: {{system.abilities.primary.Combat.Ki.totalKiAccumulation}}
        </h4>
        <div class="zeon-row">
          <div class="imbalance-field">
            <label class="path-name">
              Accumulated
            </label>
            <span class="path-name clickable ki-accumulated-manual" data-tooltip="Click to manually edit">
              {{system.abilities.primary.Combat.Ki.current}}
            </span>
          </div>
          <div class="imbalance-field">
            <label class="path-name">
              Reserve
            </label>
            <span class="path-name clickable ki-reserve-manual" data-tooltip="Click to manually edit">
              {{system.abilities.primary.Combat.Ki.reserve}}
            </span>
          </div>
          <div class="imbalance-field">
            <label class="path-name">
              Maximum
            </label>
            <span class="path-name">
              {{system.abilities.primary.Combat.Ki.totalKi}}
            </span>
          </div>
        </div>
      </div>
    </section>

    <section>
      <h3>Ki Abilities</h3>

      <div class="ki-abilities-tree">
        {{#each kiAbilities as |ability key|}}
          {{#if (isRootAbility key ../kiAbilities)}}
            {{> "systems/abf-system/templates/actors/partials/nav/domine/ki-abilities.hbs"
              ability=ability
              key=key
              kiAbilities=../kiAbilities
            }}
          {{/if}}
        {{/each}}
      </div>
    </section>

  </div>
  <div class="combat-right-core">
    <h3>
      Techniques
    </h3>

    <table class="classes-table npc-powers-table">
      <thead>
        <tr>
          <th>
            Technique
          </th>
          <th>
            Level
          </th>
          <th>
            MK Cost
          </th>
          <th>
            Ki Cost
          </th>
          <th>
            Ki Per turn
          </th>
          <th>
            Active
          </th>
          <th>
            Effects
          </th>

          {{#if @root.actor.system.lockUi}}
            <th></th>
          {{else}}
            <th class="class-actions-header">
              <a class="add-technique" data-tooltip="Add Technique">
                <i class="fas fa-plus-circle"></i>
              </a>
            </th>
          {{/if}}
        </tr>
      </thead>

      <tbody>
        {{#each actor.items as |item idx|}}
          {{#if (eq item.type "technique")}}
            <tr data-item-id="{{item.id}}" class="item-row">
              <td class="item-name item-edit clickable" data-item-id="{{item.id}}" data-index="{{idx}}">
                {{item.name}}
              </td>

              <td>
                {{item.system.level}}
              </td>
              <td>
                {{item.system.martialKnowledge}}
              </td>
              <td>
                {{item.system.ki.total}}
              </td>
              <td>
                {{item.system.ki.perTurn}}
              </td>

              <td class="item-name technique-active clickable" data-item-id="{{item.id}}" data-index="{{idx}}">
                {{#if item.system.active}}
                  <i class="fas fa-check"></i>
                {{else}}
                  <i class="fas fa-times"></i>
                {{/if}}
              </td>

              <td>
                {{item.system.effects.length}}
              </td>

            {{#if @root.actor.system.lockUi}}
            <td></td>
            {{else}}
              <td class="item-controls">
                <a class="item-delete">
                  <i class="fas fa-trash"></i>
                </a>
              </td>
            {{/if}}
            </tr>
          {{/if}}
        {{/each}}
      </tbody>
    </table>
  </div>
</div>