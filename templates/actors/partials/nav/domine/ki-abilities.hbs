<div class="ki-ability-row" data-key="{{key}}">
  <div class="ki-ability-header">
    <span class="ki-ability-name clickable" data-name="{{ability.name}}" data-tooltip="Click to see details.">
      {{ability.name}} ({{ability.mkCost}})
    </span>

    {{#if @root.actor.system.lockUi}}
      {{#if ability.purchased}}
        <i class="fas fa-check purchased"></i>
      {{else}}
        <i class="fas fa-times"></i>
      {{/if}}
    {{else}}
      {{#if ability.purchased}}
        <i class="fas fa-check ki-toggle-ability purchased"></i>
      {{else}}
        <i class="fas fa-times ki-toggle-ability"></i>
      {{/if}}
    {{/if}}
  </div>

  {{#if ability.children}}
    <div class="ki-ability-children">
      {{#each ability.children as |childKey|}}
        {{> "systems/abf-system/templates/actors/partials/nav/domine/ki-abilities.hbs"
            ability=(lookup @root.kiAbilities childKey)
            key=childKey
            kiAbilities=@root.kiAbilities
        }}
      {{/each}}
    </div>
  {{/if}}
</div>
