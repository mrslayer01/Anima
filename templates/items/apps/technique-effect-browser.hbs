<div class="technique-effect-browser">

  <div class="browser-controls">
    <input
      type="text"
      class="technique-effect-search"
      placeholder="Search effects..."
      value="{{search}}"
    />

    <select class="technique-effect-filter select">
      {{#each types}}
        <option value="{{this}}" {{#if (eq this ../filterType)}}selected{{/if}}>
          {{this}}
        </option>
      {{/each}}
    </select>
  </div>

  <div class="effects-grid">
    {{#each effects}}
      <div class="gift-entry">
        <div class="power-header">
          <h3>{{this.name}}</h3>
          <span class="power-type abf-text">{{this.type}}</span>
        </div>

        <p class="power-meta abf-text">
          <strong>Bonuses:</strong> {{this.effects.length}}
        </p>

        <p class="power-meta abf-text">
          <strong>Description:</strong> {{this.description}}
        </p>

        <div class="power-actions">
          <button class="open-effect button" data-key="{{this.key}}">Details</button>
          <button class="add-effect button" data-key="{{this.key}}">Add</button>
        </div>
      </div>
    {{/each}}
  </div>

</div>