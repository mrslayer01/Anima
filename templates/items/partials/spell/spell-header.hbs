<section class="common-fields">
  <div class="section-block">
      <table class="common-table">
        <tr>
          <td>
            <label>Level</label>
            <input type="number" name="system.level" value="{{system.level}}" />
          </td>
          <td>
            <label>Cost</label>
            <input type="number" name="system.cost" value="{{system.cost}}" />
          </td>
          <td>
            <label>Path</label>
            <select name="system.path" class="path-select select">
                <option value="light" {{#if (eq system.path "light")}}selected{{/if}}>Light</option>
                <option value="darkness" {{#if (eq system.path "darkness")}}selected{{/if}}>Darkness</option>
                <option value="creation" {{#if (eq system.path "creation")}}selected{{/if}}>Creation</option>
                <option value="destruction" {{#if (eq system.path "destruction")}}selected{{/if}}>Destruction</option>
                <option value="fire" {{#if (eq system.path "fire")}}selected{{/if}}>Fire</option>
                <option value="water" {{#if (eq system.path "water")}}selected{{/if}}>Water</option>
                <option value="earth" {{#if (eq system.path "earth")}}selected{{/if}}>Earth</option>
                <option value="air" {{#if (eq system.path "air")}}selected{{/if}}>Air</option>
                <option value="essence" {{#if (eq system.path "essence")}}selected{{/if}}>Essence</option>
                <option value="illusion" {{#if (eq system.path "illusion")}}selected{{/if}}>Illusion</option>
                <option value="necromancy" {{#if (eq system.path "necromancy")}}selected{{/if}}>Necromancy</option>
            </select>
          </td>
        </tr>
      </table>
  </div>
</section>