<form class="abf-item-sheet">
<div class="header-top">
  
    <!-- Left spacer (keeps name centered) -->
    <div class="header-top-spacer"></div>

        <!-- Item Name -->
        <input class="header-top-name"
        type="text" 
        name="name" 
        value="{{item.name}}" 
        />
    </div>
    <!-- Always render the common onto each item. -->
    {{#if (in item.type "weapon" "armor" "ammo" "commonGood")}}
      {{> "systems/abf-system/templates/items/partials/common/common.hbs"}}
    {{/if}}

    {{#if (in item.type "spell")}}
      {{> "systems/abf-system/templates/items/partials/spell/spell-header.hbs"}}
    {{/if}}

    {{#if (in item.type "technique")}}
      {{> "systems/abf-system/templates/items/partials/technique/technique-header.hbs"}}
    {{/if}}


      <!-- TABS -->
    <nav class="sheet-tabs" data-group="primary">
      {{#if (in item.type "weapon" "armor" "ammo" "spell" "technique")}}
        <a class="item" data-tab="main">Main</a>
          {{#if (in item.type "weapon" "armor")}}
          <a class="item" data-tab="final">Final Values</a>
          {{/if}}
        {{#if (in item.system.weaponType "projectile")}}
          <a class="item" data-tab="ammo">Ammo</a>
        {{/if}}
      {{/if}}
      {{#if (in item.type "weapon" "armor" "ammo" "commonGood" "technique")}}
      <a class="item" data-tab="description">Description</a>
      {{/if}}
    </nav>

    <section class="sheet-body">

      <div class="tab main" data-group="primary" data-tab="main">
        {{#if (eq item.type "weapon")}}
          {{> "systems/abf-system/templates/items/partials/weapon.hbs"}}
        {{/if}}
        {{#if (eq item.type "armor")}}
          {{> "systems/abf-system/templates/items/partials/armor.hbs"}}
        {{/if}}
        {{#if (eq item.type "ammo")}}
          {{> "systems/abf-system/templates/items/partials/ammo.hbs"}}
        {{/if}}
        {{#if (eq item.type "spell")}}
          {{> "systems/abf-system/templates/items/partials/spell.hbs"}}
        {{/if}}
        {{#if (eq item.type "technique")}}
          {{> "systems/abf-system/templates/items/partials/technique.hbs"}}
        {{/if}}
      </div>

      <div class="tab final" data-group="primary" data-tab="final">
        {{#if (eq item.type "weapon")}}
          {{> "systems/abf-system/templates/items/partials/weapon/weapon-finals.hbs"}}
        {{/if}}

        {{#if (eq item.type "armor")}}
          {{> "systems/abf-system/templates/items/partials/armor/armor-finals.hbs"}}
        {{/if}}
      </div>

      <div class="tab ammo" data-group="primary" data-tab="ammo">
        {{> "systems/abf-system/templates/items/partials/weapon/weapon-ammo.hbs"}}
      </div>
      
      <div class="tab description" data-group="primary" data-tab="description">
        {{> "systems/abf-system/templates/items/partials/common/description.hbs"}}
      </div>
    </section>

</form>